# ─────────────────────────────────────────────
#  .gitignore for Java / Maven / NetBeans project
# ─────────────────────────────────────────────

# Maven build output
target/

# NetBeans project metadata (IDE-specific, not needed by others)
nbproject/private/
nbproject/Makefile-*.mk
nbproject/Package-*.bash
build/
dist/
nbbuild/
nbdist/
nb-configuration.xml

# Compiled class files
*.class

# JAR / WAR / EAR files
*.jar
*.war
*.ear
*.nar

# Log files
*.log
logs/

# OS-generated files
.DS_Store
Thumbs.db
desktop.ini

# IntelliJ IDEA (in case anyone else opens it)
.idea/
*.iml
*.iws
*.ipr

# Eclipse
.project
.classpath
.settings/

# VS Code
.vscode/

# Environment / secrets – NEVER commit these
.env
*.properties.local
db.properties

# Heap dumps / crash logs
hs_err_pid*
replay_pid*
